# Environment Variables — copy this to `.env` and fill in your values
# NEVER commit the real .env file to git

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: https://app.supabase.com → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Set this to your chosen admin password (plain text is fine for .env on Render)
ADMIN_PASSWORD=change_me_to_a_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
